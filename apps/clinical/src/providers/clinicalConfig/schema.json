{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Clinical App Configuration Schema",
  "description": "Schema for global clinical app configuration including patient information, actions and available dashboards",
  "type": "object",
  "required": [
    "patientInformation",
    "actions",
    "dashboards",
    "consultationPad"
  ],
  "additionalProperties": false,
  "definitions": {
    "inputControl": {
      "type": "object",
      "required": ["type", "metadata", "encounterTypes", "privileges", "attributes"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "description": "Identifier matching the registered form key (e.g. encounterDetails, allergies)"
        },
        "metadata": {
          "type": "object",
          "description": "Additional metadata for the input control"
        },
        "encounterTypes": {
          "type": "array",
          "description": "Encounter types for which this control is shown",
          "items": {
            "type": "string"
          }
        },
        "privileges": {
          "type": "array",
          "description": "Privileges required to view this control",
          "items": {
            "type": "string"
          }
        },
        "attributes": {
          "type": "array",
          "description": "Form attributes configuration",
          "items": {
            "type": "object",
            "required": ["name", "required"],
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string",
                "description": "Attribute name"
              },
              "required": {
                "type": "boolean",
                "description": "Whether this attribute is required"
              }
            }
          }
        }
      }
    }
  },
  "properties": {
    "patientInformation": {
      "type": "object",
      "description": "Patient information configuration",
      "additionalProperties": false
    },
    "contextInformation": {
      "type": "object",
      "description": "Context information configuration for displaying additional patient context",
      "additionalProperties": false,
      "properties": {
        "program": {
          "type": "object",
          "description": "Program details configuration",
          "required": ["fields"],
          "additionalProperties": false,
          "properties": {
            "fields": {
              "type": "array",
              "description": "List of fields to display in program details",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "patientSearch": {
      "type": "object",
      "description": "Configuration for patient search dropdown display",
      "additionalProperties": false,
      "properties": {
        "displayFields": {
          "type": "array",
          "description": "Fields to display in patient search dropdown results. Each entry maps to a PatientSearchResult field.",
          "items": {
            "type": "object",
            "required": ["field"],
            "additionalProperties": false,
            "properties": {
              "field": {
                "type": "string",
                "enum": ["name", "identifier", "gender", "age"],
                "description": "Field name from PatientSearchResult"
              },
              "bold": {
                "type": "boolean",
                "description": "Whether to render this field in bold"
              }
            }
          }
        }
      }
    },
    "actions": {
      "type": "array",
      "description": "List of available actions"
    },
    "dashboards": {
      "type": "array",
      "description": "List of available dashboards",
      "items": {
        "type": "object",
        "required": ["name", "requiredPrivileges", "url"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "description": "Display name of the dashboard"
          },
          "requiredPrivileges": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of permissions required to access this dashboard"
          },
          "icon": {
            "type": "string",
            "description": "Icon class name for the dashboard"
          },
          "default": {
            "type": "boolean",
            "description": "Whether this is the default dashboard"
          },
          "url": {
            "type": "string",
            "description": "URL to access the dashboard data"
          }
        }
      }
    },
    "consultationPad": {
      "type": "object",
      "description": "Configuration for consultation pad forms",
      "required": ["allergyConceptMap", "inputControls"],
      "additionalProperties": true,
      "properties": {
        "allergyConceptMap": {
          "type": "object",
          "description": "UUID mappings for allergy concepts",
          "required": [
            "medicationAllergenUuid",
            "foodAllergenUuid",
            "environmentalAllergenUuid",
            "allergyReactionUuid"
          ],
          "additionalProperties": false,
          "properties": {
            "medicationAllergenUuid": {
              "type": "string",
              "description": "UUID for medication allergen concept"
            },
            "foodAllergenUuid": {
              "type": "string",
              "description": "UUID for food allergen concept"
            },
            "environmentalAllergenUuid": {
              "type": "string",
              "description": "UUID for environmental allergen concept"
            },
            "allergyReactionUuid": {
              "type": "string",
              "description": "UUID for allergy reaction concept"
            }
          }
        },
        "statDurationInMilliseconds": {
          "type": "number",
          "description": "Duration in milliseconds for which a STAT order is valid"
        },
        "inputControls": {
          "type": "array",
          "description": "Ordered list of input controls to display in the consultation pad",
          "items": {
            "$ref": "#/definitions/inputControl"
          }
        }
      }
    }
  }
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Clinical App Configuration Schema",
  "description": "Schema for global clinical app configuration including patient information, actions and available dashboards",
  "type": "object",
  "required": [
    "patientInformation",
    "actions",
    "dashboards",
    "consultationPad"
  ],
  "additionalProperties": false,
  "definitions": {
    "encounterDetailsControl": {
      "allOf": [{ "$ref": "#/definitions/inputControl" }],
      "properties": {
        "metadata": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "defaultEncounterType": {
              "type": "string",
              "description": "Encounter type name to use when none is specified by the caller"
            }
          }
        }
      }
    },
    "inputControl": {
      "type": "object",
      "required": ["metadata", "encounterTypes", "privileges", "attributes"],
      "additionalProperties": false,
      "properties": {
        "metadata": {
          "type": "object",
          "description": "Additional metadata for the input control"
        },
        "encounterTypes": {
          "type": "array",
          "description": "Encounter types for which this control is shown",
          "items": {
            "type": "string"
          }
        },
        "privileges": {
          "type": "array",
          "description": "Privileges required to view this control",
          "items": {
            "type": "string"
          }
        },
        "attributes": {
          "type": "array",
          "description": "Form attributes configuration",
          "items": {
            "type": "object",
            "required": ["key", "required"],
            "additionalProperties": false,
            "properties": {
              "key": {
                "type": "string",
                "description": "Attribute key"
              },
              "required": {
                "type": "boolean",
                "description": "Whether this attribute is required"
              }
            }
          }
        }
      }
    }
  },
  "properties": {
    "patientInformation": {
      "type": "object",
      "description": "Patient information configuration",
      "additionalProperties": false
    },
    "contextInformation": {
      "type": "object",
      "description": "Context information configuration for displaying additional patient context",
      "additionalProperties": false,
      "properties": {
        "program": {
          "type": "object",
          "description": "Program details configuration",
          "required": ["fields"],
          "additionalProperties": false,
          "properties": {
            "fields": {
              "type": "array",
              "description": "List of fields to display in program details",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "actions": {
      "type": "array",
      "description": "List of available actions"
    },
    "dashboards": {
      "type": "array",
      "description": "List of available dashboards",
      "items": {
        "type": "object",
        "required": ["name", "requiredPrivileges", "url"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "description": "Display name of the dashboard"
          },
          "requiredPrivileges": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of permissions required to access this dashboard"
          },
          "icon": {
            "type": "string",
            "description": "Icon class name for the dashboard"
          },
          "default": {
            "type": "boolean",
            "description": "Whether this is the default dashboard"
          },
          "url": {
            "type": "string",
            "description": "URL to access the dashboard data"
          }
        }
      }
    },
    "consultationPad": {
      "type": "object",
      "description": "Configuration for consultation pad forms",
      "required": ["allergyConceptMap", "encounterDetails"],
      "additionalProperties": false,
      "properties": {
        "allergyConceptMap": {
          "type": "object",
          "description": "UUID mappings for allergy concepts",
          "required": [
            "medicationAllergenUuid",
            "foodAllergenUuid",
            "environmentalAllergenUuid",
            "allergyReactionUuid"
          ],
          "additionalProperties": true,
          "properties": {
            "medicationAllergenUuid": {
              "type": "string",
              "description": "UUID for medication allergen concept"
            },
            "foodAllergenUuid": {
              "type": "string",
              "description": "UUID for food allergen concept"
            },
            "environmentalAllergenUuid": {
              "type": "string",
              "description": "UUID for environmental allergen concept"
            },
            "allergyReactionUuid": {
              "type": "string",
              "description": "UUID for allergy reaction concept"
            }
          }
        },
        "statDurationInHours": {
          "type": "number",
          "description": "Duration in hours for which a STAT order is valid"
        },
        "statDurationInMilliseconds": {
          "type": "number",
          "description": "Duration in milliseconds for which a STAT order is valid"
        },
        "encounterDetails": {
          "$ref": "#/definitions/encounterDetailsControl",
          "description": "Configuration for the encounter details form"
        },
        "allergies": {
          "$ref": "#/definitions/inputControl",
          "description": "Configuration for the allergies form"
        },
        "investigations": {
          "$ref": "#/definitions/inputControl",
          "description": "Configuration for the investigations form"
        },
        "medications": {
          "$ref": "#/definitions/inputControl",
          "description": "Configuration for the medications form"
        },
        "observationForms": {
          "$ref": "#/definitions/inputControl",
          "description": "Configuration for the observation forms panel"
        },
        "vaccinations": {
          "$ref": "#/definitions/inputControl",
          "description": "Configuration for the vaccinations form"
        },
        "conditionsAndDiagnoses": {
          "$ref": "#/definitions/inputControl",
          "description": "Configuration for the conditions and diagnoses form"
        }
      }
    }
  }
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Clinical App Configuration Schema",
  "description": "Schema for global clinical app configuration including patient information, actions and available dashboards",
  "type": "object",
  "required": [
    "patientInformation",
    "actions",
    "dashboards",
    "consultationPad"
  ],
  "additionalProperties": false,
  "properties": {
    "patientInformation": {
      "type": "object",
      "description": "Patient information configuration",
      "additionalProperties": false
    },
    "contextInformation": {
      "type": "object",
      "description": "Context information configuration for displaying additional patient context",
      "additionalProperties": false,
      "properties": {
        "program": {
          "type": "object",
          "description": "Program details configuration",
          "required": ["fields"],
          "additionalProperties": false,
          "properties": {
            "fields": {
              "type": "array",
              "description": "List of fields to display in program details",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "actions": {
      "type": "array",
      "description": "List of available actions"
    },
    "dashboards": {
      "type": "array",
      "description": "List of available dashboards",
      "items": {
        "type": "object",
        "required": ["name", "requiredPrivileges", "url"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "description": "Display name of the dashboard"
          },
          "requiredPrivileges": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of permissions required to access this dashboard"
          },
          "icon": {
            "type": "string",
            "description": "Icon class name for the dashboard"
          },
          "default": {
            "type": "boolean",
            "description": "Whether this is the default dashboard"
          },
          "url": {
            "type": "string",
            "description": "URL to access the dashboard data"
          }
        }
      }
    },
    "consultationPad": {
      "type": "object",
      "description": "Configuration for consultation pad forms",
      "required": ["allergyConceptMap"],
      "additionalProperties": true,
      "properties": {
        "allergyConceptMap": {
          "type": "object",
          "description": "UUID mappings for allergy concepts",
          "required": [
            "medicationAllergenUuid",
            "foodAllergenUuid",
            "environmentalAllergenUuid",
            "allergyReactionUuid"
          ],
          "additionalProperties": true,
          "properties": {
            "medicationAllergenUuid": {
              "type": "string",
              "description": "UUID for medication allergen concept"
            },
            "foodAllergenUuid": {
              "type": "string",
              "description": "UUID for food allergen concept"
            },
            "environmentalAllergenUuid": {
              "type": "string",
              "description": "UUID for environmental allergen concept"
            },
            "allergyReactionUuid": {
              "type": "string",
              "description": "UUID for allergy reaction concept"
            }
          }
        },
        "immunizationForm": {
          "type": "object",
          "required": [
            "vaccineConceptSetUuid",
            "routeConceptSetUuid",
            "siteConceptSetUuid",
            "notDoneStatusReasonConceptSetUuid"
          ],
          "additionalProperties": false,
          "properties": {
            "vaccineConceptSetUuid": {
              "type": "string"
            },
            "routeConceptSetUuid": {
              "type": "string"
            },
            "siteConceptSetUuid": {
              "type": "string"
            },
            "notDoneStatusReasonConceptSetUuid": {
              "type": "string"
            },
            "history": {
              "type": "object",
              "properties": {
                "fieldConfig": { "$ref": "#/definitions/immunizationFieldConfig" }
              },
              "additionalProperties": false
            },
            "notDone": {
              "type": "object",
              "properties": {
                "fieldConfig": { "$ref": "#/definitions/immunizationFieldConfig" }
              },
              "additionalProperties": false
            },
            "administration": {
              "type": "object",
              "properties": {
                "fieldConfig": { "$ref": "#/definitions/immunizationFieldConfig" }
              },
              "additionalProperties": false
            }
          }
        },
        "statDurationInHours": {
          "type": "number",
          "description": "Duration in hours for which a STAT order is valid"
        }
      }
    }
  },
  "definitions": {
    "fieldBehavior": {
      "type": "string",
      "enum": ["visible", "required", "hidden", "readonly"]
    },
    "immunizationFieldConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "doseSequence": { "$ref": "#/definitions/fieldBehavior" },
        "drug": { "$ref": "#/definitions/fieldBehavior" },
        "administeredOn": { "$ref": "#/definitions/fieldBehavior" },
        "location": { "$ref": "#/definitions/fieldBehavior" },
        "route": { "$ref": "#/definitions/fieldBehavior" },
        "site": { "$ref": "#/definitions/fieldBehavior" },
        "manufacturer": { "$ref": "#/definitions/fieldBehavior" },
        "batchNumber": { "$ref": "#/definitions/fieldBehavior" },
        "expirationDate": { "$ref": "#/definitions/fieldBehavior" },
        "notes": { "$ref": "#/definitions/fieldBehavior" },
        "statusReason": { "$ref": "#/definitions/fieldBehavior" }
      }
    }
  }
}
